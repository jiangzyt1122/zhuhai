# Youdao HTTP API parameter name is appKey, but here it should be your app ID.
YOUDAO_APP_KEY=your_youdao_app_id
YOUDAO_APP_SECRET=your_youdao_app_secret
# Public JSONP mode for static sites. This exposes your secret in the frontend bundle.
# Only use if you accept that risk.
# VITE_YOUDAO_APP_KEY=your_youdao_app_id
# VITE_YOUDAO_APP_SECRET=your_youdao_app_secret
# Optional public proxy endpoint for static deployments, for example:
# VITE_YOUDAO_PROXY_URL=https://your-domain.example/api/youdao/dict
